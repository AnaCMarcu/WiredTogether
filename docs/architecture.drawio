        <!-- Hebbian equation -->
        <mxCell id="sp_equation" value="&lt;b&gt;Hebbian Update:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Δw&lt;sub&gt;ij&lt;/sub&gt; = η·m&lt;sub&gt;ij&lt;/sub&gt;·c&lt;sub&gt;ij&lt;/sub&gt;·(1-w&lt;sub&gt;ij&lt;/sub&gt;) - λ·w&lt;sub&gt;ij&lt;/sub&gt;&lt;br&gt;&lt;br&gt;m(t) = tanh(β · reward)&lt;br&gt;c&lt;sub&gt;ij&lt;/sub&gt; = I(dist ≤ d) · g&lt;sub&gt;i&lt;/sub&gt; · g&lt;sub&gt;j&lt;/sub&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#0288D1;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
