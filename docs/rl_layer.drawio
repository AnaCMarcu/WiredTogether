        <mxCell id="buffer_api" value="&lt;b&gt;API:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;store_action(prompt, idx, logp, v)&lt;br&gt;store_reward(reward, done)&lt;br&gt;compute_gae(γ, λ, last_value)&lt;br&gt;sample_batches(mini_batch=8)&lt;br&gt;filter_by_keyword(skill)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="755" width="200" height="65" as="geometry" />
