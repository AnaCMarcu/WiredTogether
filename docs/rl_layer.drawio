        <mxCell id="heads_title" value="&lt;b&gt;3. Classification Heads&lt;/b&gt;  &lt;font color=&quot;#7E57C2&quot;&gt;(trained by action-level PPO)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
