        </mxCell>

        <mxCell id="value_head" value="&lt;b&gt;ValueHead&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;nn.Linear(H → 256) → Tanh&lt;br&gt;→ nn.Linear(256 → 1)&lt;br&gt;&lt;font color=&quot;#2D7600&quot;&gt;&lt;b&gt;TRAINABLE&lt;/b&gt;&lt;/font&gt;&lt;br&gt;outputs V(s)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2D7600;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
