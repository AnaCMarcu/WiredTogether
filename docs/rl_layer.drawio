        <mxCell id="a_cat_output" style="rounded=1;strokeColor=#D6956B;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="categorical" target="output_action">
