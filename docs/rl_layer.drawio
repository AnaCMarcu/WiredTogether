        <mxCell id="prompt_box" value="&lt;b&gt;1. Prompt Construction&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Concatenates all context into text:&lt;br&gt;&lt;code&gt;Task: {task}\nLast action: ...\nCritique: ...\n&lt;br&gt;Skills: ...\nEpisodes: ...\nBeliefs: ...&lt;/code&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9673A6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
