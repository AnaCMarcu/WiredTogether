        <!-- Env reward arrow -->
        <mxCell id="env_reward" value="&lt;b&gt;Environment&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;reward, done&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6d0de;strokeColor=#996185;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="720" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="a_env_buf" style="rounded=1;strokeColor=#996185;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="env_reward" target="buffer_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_env_buf_label" value="store_reward(r, done)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#996185;" vertex="1" connectable="0" parent="a_env_buf">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint y="-12" as="offset" /></mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- STEP 5a: ACTION-LEVEL PPO                    -->
        <!-- ============================================ -->
        <mxCell id="action_ppo_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;strokeWidth=3;dashed=0;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="870" width="430" height="280" as="geometry" />
        </mxCell>
        <mxCell id="action_ppo_title" value="&lt;font style=&quot;font-size: 14px;&quot; color=&quot;#7E57C2&quot;&gt;&lt;b&gt;5a. ACTION-LEVEL PPO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#7E57C2&quot;&gt;Automatic — every update_interval=64 steps&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="460" y="875" width="330" height="40" as="geometry" />
        </mxCell>

        <mxCell id="gae_step" value="&lt;b&gt;GAE Computation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;δ = r + γV(s') - V(s)&lt;br&gt;A = Σ (γλ)&lt;sup&gt;t&lt;/sup&gt; δ&lt;sub&gt;t&lt;/sub&gt;&lt;br&gt;R = A + V(s)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4C5E2;strokeColor=#7E57C2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="920" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ppo_clip" value="&lt;b&gt;PPO Clipped Objectives&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;b&gt;Policy:&lt;/b&gt; -min(r·A, clip(r, 1±ε)·A)&lt;br&gt;where r = π&lt;sub&gt;new&lt;/sub&gt;(a|s) / π&lt;sub&gt;old&lt;/sub&gt;(a|s)&lt;br&gt;&lt;br&gt;&lt;b&gt;Value:&lt;/b&gt; max(MSE(V, R), MSE(V&lt;sub&gt;clip&lt;/sub&gt;, R))&lt;br&gt;&lt;br&gt;&lt;b&gt;Entropy:&lt;/b&gt; -H(π) for exploration&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7E57C2;strokeColor=#5E35B1;fontColor=#FFFFFF;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="995" width="250" height="95" as="geometry" />
        </mxCell>

        <mxCell id="total_loss_action" value="&lt;b&gt;Total Loss:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;L = L&lt;sub&gt;policy&lt;/sub&gt; + 0.5·L&lt;sub&gt;value&lt;/sub&gt; - 0.01·H&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#5E35B1;strokeColor=#4527A0;fontColor=#FFFFFF;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="440" y="1105" width="250" height="35" as="geometry" />
        </mxCell>

        <!-- What gets updated box -->
        <mxCell id="updated_action" value="&lt;b&gt;What gets updated:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;1. &lt;font color=&quot;#2D7600&quot;&gt;&lt;b&gt;ActionHead&lt;/b&gt;&lt;/font&gt; weights&lt;br&gt;2. &lt;font color=&quot;#2D7600&quot;&gt;&lt;b&gt;ValueHead&lt;/b&gt;&lt;/font&gt; weights&lt;br&gt;3. &lt;font color=&quot;#2D7600&quot;&gt;&lt;b&gt;LoRA&lt;/b&gt;&lt;/font&gt; adapter (via backprop through h)&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#AE4132&quot;&gt;Base LLM stays FROZEN&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2D7600;fontSize=10;align=left;spacingLeft=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="710" y="920" width="120" height="110" as="geometry" />
        </mxCell>

        <mxCell id="schedule_action" value="&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;b&gt;Schedule:&lt;/b&gt;&lt;br&gt;4 PPO epochs&lt;br&gt;mini-batch = 8&lt;br&gt;lr = 3e-4 (Adam)&lt;br&gt;grad clip = 0.5&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="710" y="1040" width="120" height="75" as="geometry" />
        </mxCell>

        <mxCell id="a_gae_ppo" style="rounded=1;strokeColor=#7E57C2;strokeWidth=1;" edge="1" parent="1" source="gae_step" target="ppo_clip">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_ppo_loss" style="rounded=1;strokeColor=#7E57C2;strokeWidth=1;" edge="1" parent="1" source="ppo_clip" target="total_loss_action">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Arrow buffer → action PPO -->
        <mxCell id="a_buf_appo" style="rounded=1;strokeColor=#7E57C2;strokeWidth=2;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.3;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="buffer_box" target="action_ppo_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_buf_appo_label" value="&lt;b&gt;should_update()&lt;/b&gt;&lt;br&gt;len(buffer) ≥ 64" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#7E57C2;" vertex="1" connectable="0" parent="a_buf_appo">
          <mxGeometry x="-0.3" relative="1" as="geometry"><mxPoint x="-50" as="offset" /></mxGeometry>
        </mxCell>

        <!-- Gradient arrow back to model -->
        <mxCell id="a_grad_back" style="rounded=1;strokeColor=#2D7600;strokeWidth=3;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" parent="1" source="updated_action" target="lora_adapter">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="770" y="430" />
              <mxPoint x="835" y="430" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a_grad_back_label" value="&lt;font color=&quot;#2D7600&quot;&gt;&lt;b&gt;∇L backprop&lt;/b&gt;&lt;br&gt;updates LoRA + heads&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;" vertex="1" connectable="0" parent="a_grad_back">
          <mxGeometry x="0.3" relative="1" as="geometry"><mxPoint x="45" as="offset" /></mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- STEP 5b: TOKEN-LEVEL PPO                     -->
        <!-- ============================================ -->
        <mxCell id="token_ppo_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;strokeWidth=3;dashed=0;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1000" y="660" width="540" height="500" as="geometry" />
        </mxCell>
        <mxCell id="token_ppo_title" value="&lt;font style=&quot;font-size: 14px;&quot; color=&quot;#E91E63&quot;&gt;&lt;b&gt;5b. TOKEN-LEVEL PPO&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 10px;&quot; color=&quot;#E91E63&quot;&gt;Agent-triggered — self-assessed via learning_belief.txt&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1070" y="665" width="400" height="40" as="geometry" />
        </mxCell>

        <!-- Hard guards -->
        <mxCell id="guards" value="&lt;b&gt;Hard Guards (checked first):&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;1. auto_token_opt enabled?&lt;br&gt;2. Full window of success data (10 steps)?&lt;br&gt;3. Cooldown elapsed since last training?&lt;br&gt;4. ≥ 32 transitions in buffer?&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#E91E63;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="715" width="230" height="80" as="geometry" />
        </mxCell>

        <!-- Stats compilation -->
        <mxCell id="stats_box" value="&lt;b&gt;Performance Stats:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;• success_rate = successes / window&lt;br&gt;• reward_trend: improving / stable / declining&lt;br&gt;• failure_description: consecutive fails&lt;br&gt;• recent_actions list&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="810" width="230" height="80" as="geometry" />
        </mxCell>

        <!-- Data sources for stats -->
        <mxCell id="critic_input" value="&lt;b&gt;Critic&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;success/failure&lt;br&gt;record_success()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EA6B66;strokeColor=#B85450;fontColor=#FFFFFF;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="850" width="110" height="45" as="geometry" />
        </mxCell>
        <mxCell id="autocurr_input" value="&lt;b&gt;AutoCurriculum&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;current_task&lt;br&gt;record_context()&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="910" width="110" height="45" as="geometry" />
        </mxCell>
        <mxCell id="a_critic_stats" style="rounded=1;strokeColor=#B85450;strokeWidth=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;" edge="1" parent="1" source="critic_input" target="stats_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_autocurr_stats" style="rounded=1;strokeColor=#82B366;strokeWidth=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.7;entryDx=0;entryDy=0;" edge="1" parent="1" source="autocurr_input" target="stats_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Learning belief prompt -->
        <mxCell id="learn_prompt" value="&lt;b&gt;learning_belief.txt&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Filled with stats → sent to LLM&lt;br&gt;&lt;br&gt;&quot;You are a learning agent...&lt;br&gt;You can request deep fine-tuning...&lt;br&gt;This is YOUR decision about&lt;br&gt;your own learning.&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#E91E63;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1020" y="910" width="230" height="90" as="geometry" />
        </mxCell>

        <!-- LLM response -->
        <mxCell id="llm_decision" value="&lt;b&gt;LLM Response:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;{needs_training: bool,&lt;br&gt; reason: &quot;...&quot;,&lt;br&gt; skill_focus: &quot;mining stone&quot;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1020" y="1020" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- Token PPO math -->
        <mxCell id="token_math" value="&lt;b&gt;Token-Level PPO:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;Per-token log-probs over full sequence:&lt;br&gt;log p(x&lt;sub&gt;t&lt;/sub&gt;|x&lt;sub&gt;&lt;t&lt;/sub&gt;) across prompt+response&lt;br&gt;&lt;br&gt;Sequence-level ratio:&lt;br&gt;r = exp(Σ log p&lt;sub&gt;new&lt;/sub&gt; - Σ log p&lt;sub&gt;old&lt;/sub&gt;)&lt;br&gt;&lt;br&gt;Loss = -min(r·A, clip(r, 1±ε)·A)&lt;br&gt;A = normalized reward&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E91E63;strokeColor=#C2185B;fontColor=#FFFFFF;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1270" y="790" width="240" height="140" as="geometry" />
        </mxCell>

        <!-- What token PPO updates -->
        <mxCell id="updated_token" value="&lt;b&gt;What gets updated:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;ONLY &lt;font color=&quot;#2D7600&quot;&gt;&lt;b&gt;LoRA&lt;/b&gt;&lt;/font&gt; adapter&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#AE4132&quot;&gt;NOT ActionHead&lt;br&gt;NOT ValueHead&lt;br&gt;NOT Base LLM&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2D7600;fontSize=10;align=left;spacingLeft=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="1270" y="950" width="150" height="90" as="geometry" />
        </mxCell>

        <mxCell id="token_schedule" value="&lt;font style=&quot;font-size: 9px;&quot;&gt;&lt;b&gt;Schedule:&lt;/b&gt;&lt;br&gt;2 token-opt epochs&lt;br&gt;mini-batch = 8&lt;br&gt;cooldown = 10 steps&lt;br&gt;min samples = 32&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="1060" width="130" height="75" as="geometry" />
        </mxCell>

        <!-- Arrows inside token PPO -->
        <mxCell id="a_guard_stats" style="rounded=1;strokeColor=#E91E63;strokeWidth=1;" edge="1" parent="1" source="guards" target="stats_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_guard_stats_label" value="pass" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#E91E63;" vertex="1" connectable="0" parent="a_guard_stats">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint x="-15" as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="a_stats_prompt" style="rounded=1;strokeColor=#E91E63;strokeWidth=1;" edge="1" parent="1" source="stats_box" target="learn_prompt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_prompt_decision" style="rounded=1;strokeColor=#E91E63;strokeWidth=1;" edge="1" parent="1" source="learn_prompt" target="llm_decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_prompt_decision_label" value="LLM call" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#E91E63;" vertex="1" connectable="0" parent="a_prompt_decision">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint x="-20" as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="a_decision_math" style="rounded=1;strokeColor=#E91E63;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;" edge="1" parent="1" source="llm_decision" target="token_math">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_decision_math_label" value="&lt;b&gt;needs_training = true&lt;/b&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#E91E63;" vertex="1" connectable="0" parent="a_decision_math">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint y="-12" as="offset" /></mxGeometry>
        </mxCell>

        <!-- Arrow buffer → token PPO -->
        <mxCell id="a_buf_tppo" style="rounded=1;strokeColor=#E91E63;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.2;entryDx=0;entryDy=0;" edge="1" parent="1" source="buffer_box" target="token_ppo_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_buf_tppo_label" value="transitions&lt;br&gt;(optionally filtered&lt;br&gt;by skill_focus)" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=9;fontColor=#E91E63;" vertex="1" connectable="0" parent="a_buf_tppo">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint y="-15" as="offset" /></mxGeometry>
        </mxCell>

        <!-- Token PPO gradient back to LoRA -->
        <mxCell id="a_token_grad" style="rounded=1;strokeColor=#E91E63;strokeWidth=3;dashed=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="updated_token" target="lora_adapter">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1540" y="920" />
              <mxPoint x="1540" y="250" />
              <mxPoint x="930" y="250" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a_token_grad_label" value="&lt;font color=&quot;#E91E63&quot;&gt;&lt;b&gt;∇L backprop&lt;/b&gt;&lt;br&gt;updates LoRA ONLY&lt;/font&gt;" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=10;" vertex="1" connectable="0" parent="a_token_grad">
          <mxGeometry x="0.5" relative="1" as="geometry"><mxPoint x="50" as="offset" /></mxGeometry>
        </mxCell>

        <!-- ============================================ -->
        <!-- LEGEND                                       -->
        <!-- ============================================ -->
        <mxCell id="legend_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;strokeWidth=1;dashed=0;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="440" width="310" height="230" as="geometry" />
        </mxCell>
        <mxCell id="legend_title" value="&lt;b&gt;Legend&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="145" y="445" width="60" height="20" as="geometry" />
        </mxCell>

        <mxCell id="leg1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2D7600;fontSize=9;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="475" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg1t" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Trainable parameters&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="472" width="140" height="20" as="geometry" />
        </mxCell>

        <mxCell id="leg2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontSize=9;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="500" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg2t" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Action-level PPO (automatic)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="497" width="180" height="20" as="geometry" />
        </mxCell>

        <mxCell id="leg3" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#E91E63;fontSize=9;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="525" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg3t" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Token-level PPO (agent-triggered)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="522" width="210" height="20" as="geometry" />
        </mxCell>

        <mxCell id="leg4" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="550" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg4t" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Trajectory data storage&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="80" y="547" width="150" height="20" as="geometry" />
        </mxCell>

        <mxCell id="leg5" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=9;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="50" y="575" width="20" height="15" as="geometry" />
        </mxCell>
        <mxCell id="leg5t" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Intermediate representations&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
