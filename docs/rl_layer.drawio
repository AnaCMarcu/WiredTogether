        <!-- Action space list -->
        <mxCell id="action_space" value="&lt;b&gt;17 Discrete Actions:&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 8px;&quot;&gt;NoOp · MoveForward · MoveBackward&lt;br&gt;MoveLeft · MoveRight · Jump · Sneak&lt;br&gt;Dig · Place · Slot1-5&lt;br&gt;TurnRight · TurnLeft · LookDown&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666666;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="860" y="475" width="190" height="75" as="geometry" />
        </mxCell>
