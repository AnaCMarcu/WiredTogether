        <mxCell id="tokenizer" value="&lt;b&gt;Tokenizer&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;AutoTokenizer&lt;br&gt;prompt → input_ids&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4C5E2;strokeColor=#9673A6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="275" width="110" height="55" as="geometry" />
        </mxCell>

        <mxCell id="base_model" value="&lt;b&gt;Base LLM&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;AutoModelForCausalLM&lt;br&gt;&lt;font color=&quot;#AE4132&quot;&gt;(FROZEN — no gradient)&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4C5E2;strokeColor=#9673A6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="575" y="275" width="140" height="55" as="geometry" />
        </mxCell>

        <mxCell id="lora_adapter" value="&lt;b&gt;LoRA Adapter&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;r=8, α=16, dropout=0.05&lt;br&gt;targets: q_proj, v_proj&lt;br&gt;&lt;font color=&quot;#2D7600&quot;&gt;&lt;b&gt;TRAINABLE&lt;/b&gt;&lt;/font&gt;&lt;br&gt;per-role: gatherer/hunter/defender&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2D7600;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="740" y="270" width="190" height="75" as="geometry" />
        </mxCell>

