        </mxCell>

        <mxCell id="categorical" value="&lt;b&gt;Categorical(logits)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;sample() → action_idx&lt;br&gt;log_prob(a) → old_log_prob&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=10;" vertex="1" parent="1">
