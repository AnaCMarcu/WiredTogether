        <mxCell id="model_group" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#7E57C2;strokeWidth=2;dashed=0;fontSize=11;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="540" height="170" as="geometry" />
        </mxCell>
        <mxCell id="model_title" value="&lt;b&gt;2. Feature Encoding&lt;/b&gt;  &lt;font color=&quot;#7E57C2&quot;&gt;(LLM as backbone, NOT as text generator)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=11;" vertex="1" parent="1">
