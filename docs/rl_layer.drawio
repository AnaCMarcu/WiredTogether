          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================ -->
        <!-- OUTPUT: Action dict returned                  -->
        <!-- ============================================ -->
        <mxCell id="output_action" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;Output&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;{&quot;action&quot;: &quot;MoveForward&quot;,&lt;br&gt; &quot;thoughts&quot;: &quot;RL policy (step N)&quot;,&lt;br&gt; &quot;communication&quot;: &quot;&quot;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFB570;strokeColor=#D6956B;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
