        </mxCell>

        <mxCell id="transition" value="&lt;b&gt;Transition&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 9px;&quot;&gt;prompt_text: str&lt;br&gt;action_idx: int&lt;br&gt;old_log_prob: float  ← log π&lt;sub&gt;old&lt;/sub&gt;(a|s)&lt;br&gt;old_value: float  ← V&lt;sub&gt;old&lt;/sub&gt;(s)&lt;br&gt;reward: float&lt;br&gt;done: bool&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
